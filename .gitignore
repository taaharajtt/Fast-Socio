# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# next-pwa generated service worker (regenerated on every build)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/swe-worker-*.js
/public/fallback-*.js

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI local artifacts
/supabase/.temp
/supabase/.branches

# Local handoff doc (contains secrets) — never commit
/TASK_STATE.md

.vercel
.env*

# Internal audit report — kept locally, never deployed (contained a credential string that failed the Vercel deploy security scan).
SECURITY.md

# Local-only launch/security audit docs — never publish to the public repo
AUDIT_REPORT.md
IMPLEMENTATION_PLAN.md
FAST-SOCIO-LaunchReadiness.md

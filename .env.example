# FAST SOCIO — environment variables template.
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (Phase 0/1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; used by route handlers / Edge Functions. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push / VAPID (Phase 10) ---
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is safe to expose; private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for push services (mailto: or https:).
VAPID_SUBJECT=mailto:admin@fastsocio.app

# --- Sentry error + performance monitoring (launch Blocker 0.6 / LR-05) ---
# Public DSN — safe to expose; enables client + server error reporting.
# Leave empty to disable Sentry entirely (local dev / CI stay quiet).
NEXT_PUBLIC_SENTRY_DSN=
# Fraction of transactions traced (0..1). Defaults to 0.1 if unset.
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Build-time source-map upload (set in CI/Vercel prod only — never commit).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

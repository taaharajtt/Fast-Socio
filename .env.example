# FAST SOCIO — environment variables template.
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (Phase 0/1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; used by route handlers / Edge Functions. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push / VAPID (Phase 10) ---
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is safe to expose; private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for push services (mailto: or https:).
VAPID_SUBJECT=mailto:admin@fastsocio.app
